# ============================================================
# IITIIMJobAssistant — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — add it to .gitignore
# ============================================================


# ------------------------------------------------------------
# GOOGLE OAUTH 2.0
# ------------------------------------------------------------
# How to get these:
#   1. Go to https://console.cloud.google.com/
#   2. Create a new project (or select existing)
#   3. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
#   4. Application type: Web application
#   5. Authorised JavaScript origins:
#        http://localhost:3000          (local dev)
#        https://yourdomain.com         (production)
#   6. Authorised redirect URIs:
#        http://localhost:3000/auth/google/callback
#        https://yourdomain.com/auth/google/callback
#   7. Copy the Client ID and Client Secret below

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# OAuth scopes we request (space-separated)
# openid       → identity token
# email        → user's email address
# profile      → name + profile picture
GOOGLE_OAUTH_SCOPES=openid email profile


# ------------------------------------------------------------
# SESSION / JWT
# ------------------------------------------------------------
# Used to sign session cookies and JWT tokens.
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

SESSION_SECRET=replace-with-a-long-random-string-min-64-chars
JWT_SECRET=replace-with-another-long-random-string-min-64-chars
JWT_EXPIRES_IN=7d


# ------------------------------------------------------------
# DATABASE  (choose one)
# ------------------------------------------------------------
# Option A — PostgreSQL (recommended for production)
DATABASE_URL=postgresql://user:password@localhost:5432/iitiim_db

# Option B — MongoDB
# MONGODB_URI=mongodb://localhost:27017/iitiim_db


# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Admin panel URL (can be same origin on a different route)
ADMIN_URL=http://localhost:3000/admin


# ------------------------------------------------------------
# EMAIL  (for approval/rejection notifications)
# ------------------------------------------------------------
# Any SMTP provider — examples: SendGrid, Postmark, Gmail SMTP
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@iitiim.ai


# ------------------------------------------------------------
# SECURITY
# ------------------------------------------------------------
# Comma-separated list of admin emails allowed to access /admin
ADMIN_EMAILS=you@yourdomain.com

# Rate limiting — max signup attempts per IP per hour
RATE_LIMIT_SIGNUPS=10

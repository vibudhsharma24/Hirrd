                       (SELECT ab.subscription_status FROM agent_buyers ab
                        WHERE ab.email = u.email
                        ORDER BY ab.created_at DESC LIMIT 1) as subscription_status
                FROM users u
                {where}
                ORDER BY u.{sort_by} {sort_dir}
                LIMIT ? OFFSET ?""",
            params + [per_page, offset],
        ).fetchall()


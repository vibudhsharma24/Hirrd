          <div class="flex justify-between text-[13px]"><span class="text-ink-700/60">Full name</span><span class="font-medium">${U.full_name || U.name}</span></div>
          <div class="h-px bg-ink-900/5"></div>
          <div class="flex justify-between text-[13px]"><span class="text-ink-700/60">Email</span><span class="font-medium">${U.email}</span></div>
          <div class="h-px bg-ink-900/5"></div>
          <div class="flex justify-between text-[13px]"><span class="text-ink-700/60">Mobile</span><span class="font-medium">${U.mobile_number || '—'}</span></div>
          <div class="h-px bg-ink-900/5"></div>
          <div class="flex justify-between text-[13px]"><span class="text-ink-700/60">LinkedIn</span><span class="font-medium">${U.linkedin_url ? '<a href="'+U.linkedin_url+'" target="_blank" class="text-brand-700">View ↗</a>' : '—'}</span></div>
          <div class="h-px bg-ink-900/5"></div>
          <div class="flex justify-between text-[13px]"><span class="text-ink-700/60">Member since</span><span class="font-medium">${U.submitted_at ? new Date(U.submitted_at).toLocaleDateString() : '—'}</span></div>
        </div>
      </div>

      <!-- Agent Card -->
      <div class="sm-card p-6">
        <div class="text-[12px] font-semibold tracking-widest text-brand-700 mb-4">JOB SEEKER AGENT</div>
        ${U.is_agent_buyer ? `
          ${!U.agent_buyer ? `
            <!-- Resume upload needed -->
            <div class="text-center py-6">
              <div class="w-14 h-14 mx-auto rounded-2xl bg-gradient-to-br from-amber-400 to-orange-500 text-white grid place-items-center shadow-soft">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              </div>
              <h3 class="font-display font-bold text-lg mt-4">Upload your resume</h3>
              <p class="mt-2 text-[13px] text-ink-700/70">Your Pro Agent is active! Upload your resume to start auto-applying.</p>
              <label class="mt-4 inline-flex px-5 py-2.5 rounded-xl bg-ink-900 text-white font-semibold hover:bg-brand-700 transition text-[14px] cursor-pointer">
                <input type="file" accept=".pdf,.doc,.docx" class="hidden" onchange="uploadDashboardResume(event)"/>
                Choose Resume File
              </label>
              <div id="dashUploadStatus" class="mt-3 text-[13px] hidden"></div>
            </div>
          ` : `
            <div class="flex items-center gap-3 p-4 rounded-xl ${isActive ? 'bg-emerald-50 border border-emerald-100' : 'bg-amber-50 border border-amber-100'}">
              ${isActive ? '<span class="pulse-dot"></span>' : '<span class="w-2 h-2 rounded-full bg-amber-500"></span>'}
              <div class="flex-1">
                <div class="font-semibold text-[14px]">${isActive ? 'Agent is running' : agentStatus === 'paused' ? 'Agent paused' : agentStatus === 'error' ? 'Agent error' : 'Agent inactive'}</div>
                <div class="text-[12px] text-ink-700/60">${isActive ? 'Processing applications automatically' : 'Press Start to begin'}</div>
              </div>
              <button onclick="${isActive ? 'stopAgent()' : 'startAgent()'}" class="px-4 py-2 rounded-lg text-[13px] font-semibold ${isActive ? 'bg-rose-100 text-rose-700 hover:bg-rose-200' : 'bg-emerald-100 text-emerald-700 hover:bg-emerald-200'} transition">
                ${isActive ? 'Stop' : 'Start'}
              </button>
            </div>
            <div class="mt-4 grid grid-cols-2 gap-3">
              <div class="p-3 rounded-xl bg-ink-900/[.03]"><div class="text-[11px] text-ink-700/50">Today</div><div class="font-display font-bold text-lg mt-1">0</div><div class="text-[11px] text-ink-700/50">applications</div></div>
              <div class="p-3 rounded-xl bg-ink-900/[.03]"><div class="text-[11px] text-ink-700/50">Total</div><div class="font-display font-bold text-lg mt-1">${U.agent_usage_count || 0}</div><div class="text-[11px] text-ink-700/50">applications</div></div>
            </div>
          `}
        ` : `
          <div class="text-center py-6">
            <div class="w-14 h-14 mx-auto rounded-2xl bg-gradient-to-br from-ink-900 to-brand-700 text-white grid place-items-center shadow-soft">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="5" width="16" height="14" rx="3"/><path d="M9 10h.01M15 10h.01M9 15h6"/></svg>
            </div>
            <h3 class="font-display font-bold text-lg mt-4">Activate your Job Seeker Agent</h3>
            <p class="mt-2 text-[13px] text-ink-700/70">Let AI discover and apply to roles on your behalf.</p>
            <a href="/pay" class="mt-4 inline-flex px-5 py-2.5 rounded-xl bg-ink-900 text-white font-semibold hover:bg-brand-700 transition text-[14px]">Subscribe — ₹2,000/mo</a>
          </div>
        `}
      </div>
    </div>
  </div>`;
}

async function logout() {
  try { await fetch('/api/logout', { method: 'POST' }); } catch {}
  window.location.href = '/login';
}

async function startAgent() {
  try {
    const res = await fetch('/api/agent/start', { method: 'POST' });
    const data = await res.json();
    if (data.ok) { loadDashboard(); }
    else { alert(data.error || 'Could not start agent'); }
  } catch (e) { alert('Error: ' + e.message); }
}

async function stopAgent() {
  try {
    const res = await fetch('/api/agent/stop', { method: 'POST' });
    const data = await res.json();
    if (data.ok) { loadDashboard(); }
    else { alert(data.error || 'Could not stop agent'); }
  } catch (e) { alert('Error: ' + e.message); }
}

async function uploadDashboardResume(event) {
  const file = event.target.files[0];
  if (!file) return;
  const statusEl = document.getElementById('dashUploadStatus');
  statusEl.className = 'mt-3 text-[13px] text-brand-700';
  statusEl.textContent = 'Uploading...';
  statusEl.classList.remove('hidden');
  try {
    const formData = new FormData();
    formData.append('name', U.name || '');
    formData.append('last_name', U.last_name || '');
    formData.append('email', U.email || '');
    formData.append('resume', file);
    const res = await fetch('/api/agent-buyers', { method: 'POST', body: formData });
    const data = await res.json();
    if (data.ok) {
      statusEl.className = 'mt-3 text-[13px] text-emerald-700';
      statusEl.textContent = '✓ Resume uploaded! Refreshing...';
      setTimeout(() => loadDashboard(), 1000);
    } else {
      statusEl.className = 'mt-3 text-[13px] text-rose-700';
      statusEl.textContent = (data.errors || ['Upload failed']).join(', ');
    }
  } catch (err) {
    statusEl.className = 'mt-3 text-[13px] text-rose-700';
    statusEl.textContent = 'Error: ' + err.message;
  }
}

loadDashboard();
</script>
</body>
</html>
```

- **Three-state agent card**:
  1. **No subscription** → "Activate your Job Seeker Agent" + Subscribe button
  2. **Subscription active, no resume** → "Upload your resume" card with file picker
  3. **Subscription + resume** → Agent status (running/inactive) with **Start/Stop buttons**
- Added `startAgent()`, `stopAgent()`, `uploadDashboardResume()` JavaScript functions

